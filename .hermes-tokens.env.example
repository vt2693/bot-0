# Copy to ~/.hermes-tokens.env on Android/Termux. Do not commit real secrets.
# Required
export TELEGRAM_BOT_TOKEN="<bot-token>"
export GROQ_API_KEY="<groq-key>"

# Router-0 (at least one required: key or base URL; or leave both empty to use fallback)
export ROUTER_0_API_KEY="<router-0-key>"
export ROUTER_0_BASE_URL="https://vt2693-router-0.hf.space/v1"

# Optional LLM providers (alternative to router-0)
export NVIDIA_API_KEY=""
export COMPOSIO_CONSUMER_API_KEY=""
export OPENCODE_ZEN_API_KEY=""
export GOOGLE_API_KEY=""
export ANTHROPIC_API_KEY=""
export OPENAI_API_KEY=""

# Optional config
export TELEGRAM_ALLOWED_USERS=""
export JIRA_EPICS=""

# Hermes config (set by setup_android.sh)
export PROVIDER="router_0"
export BROADCAST_CHAT_ID=""
export MEMORY_SPACE_ID="none"

# Android/Termux only
export WORK_DIR="/sdcard/Download"
export POLL_INTERVAL="1"
